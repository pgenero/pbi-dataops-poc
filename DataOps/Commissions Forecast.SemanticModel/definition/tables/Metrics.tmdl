	measure 'INV002 Outside Agents' =
			
			CALCULATE(
			    [INV000 Base Commission Sum],
			    COM_CATEGORY[ComCatID] = 2
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 01.Invoice
		lineageTag: 7c33bf1b-b9ed-48e0-a70e-2c6518a56c15

