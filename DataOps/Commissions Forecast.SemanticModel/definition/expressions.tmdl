		    #"Filtered by Snapshot" = Table.SelectRows(#"Expanded Data and Snapshot", each [Name] = [Snapshot]),
		    #"Removed Name" = Table.RemoveColumns(#"Filtered by Snapshot",{"Name"})
		in
		    #"Removed Name"
