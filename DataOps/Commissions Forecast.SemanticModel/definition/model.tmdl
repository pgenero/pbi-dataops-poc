model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

queryGroup fact_Tables

	annotation PBI_QueryGroupOrder = 3

queryGroup dim_Tables

	annotation PBI_QueryGroupOrder = 4

queryGroup Transform\Calendar

	annotation PBI_QueryGroupOrder = 1

queryGroup Parameters

	annotation PBI_QueryGroupOrder = 0

queryGroup Transform

	annotation PBI_QueryGroupOrder = 1

queryGroup Transform\History_Invoices

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Invoice_Distribution","Invoice_Payment","History_InvoiceDist","CALENDAR","CalendarEndDate","AGENTS","DEALS","INVOICES","Metrics","ForecastStart","FilesFolder","Server_Name","DB_Name","fxHistoryFiles","Last_History_Update","History_InvoiceDist_Consolidated","History_InvoiceDist_Index","COM_CATEGORY"]

annotation PBI_ProTooling = ["DaxQueryView_Desktop","CalcGroup","TMDLView_Desktop","DevMode"]

ref table Invoice_Distribution
ref table CALENDAR
ref table AGENTS
ref table Invoice_Payment
ref table DEALS
ref table INVOICES
ref table Metrics
ref table _stateView
ref table _forceZero
ref table _timeIntelligence
