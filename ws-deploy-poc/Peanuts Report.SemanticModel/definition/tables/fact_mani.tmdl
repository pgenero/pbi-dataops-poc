				    #"Added Conditional Column" = Table.AddColumn(#"Changed Type", "departamento_id_fix", each if [departamento_id] = null then (([provincia_id]*1000)+999) else [departamento_id]),
				    #"Added Custom" = Table.AddColumn(#"Added Conditional Column", "date", each [anio] & "-01-01"),
