	measure 'PAY007 Outsede Agents (DueDate)' =
			
			CALCULATE(
			    [PAY002 Outside Agents],
			    USERELATIONSHIP( 'CALENDAR'[Date], Invoice_Payment[Due Date] )
			)
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
