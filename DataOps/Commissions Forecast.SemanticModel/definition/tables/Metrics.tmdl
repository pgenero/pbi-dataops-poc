	measure 'TAG005 Current Month' =
			
			VAR _maxMonth = MAX( 'CALENDAR'[Month_Number] )
			RETURN
			    CALCULATE(
			        MAX( 'CALENDAR'[Month_Year] ),
			        'CALENDAR'[Month_Number] = _maxMonth)
