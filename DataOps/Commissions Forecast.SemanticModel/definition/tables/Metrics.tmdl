	measure 'TAG001 Forecast Period' =
			
			var _firstMonth =
			CALCULATE(
			    MIN('CALENDAR'[Month_First_Day]),
			    'CALENDAR'[Month_Offset] >= 0
			)
			RETURN
			"» Forecast period from " & _firstMonth & " to " & MAX('CALENDAR'[Month_Last_Day] )
