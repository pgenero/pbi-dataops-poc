model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		fastCombine
		legacyRedirects
		returnErrorValuesAsNull

queryGroup Names_Queries

	annotation PBI_QueryGroupOrder = 0

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["SalesSupermarket","dimCategory","SalesB2B","ConsumerIndex","dimIndex","Invoices","Names","Names2529","Names3034","Names3539","Names4044","Names4549","Names5054","Names5559","Names6064","Names6569"]

annotation PBI_ProTooling = ["DevMode"]

ref table SalesSupermarket
ref table Calendar
ref table dimCategory
ref table SalesB2B
ref table ConsumerIndex
ref table dimIndex
ref table Invoices
ref table Names

ref cultureInfo en-US

