table fact_mani
	lineageTag: b2e43d96-0c36-480a-88f0-7f3e2a5d3064

	measure BaseMeasureMani = SUM( fact_mani[Value] )
		formatString: 0
		lineageTag: 63d82ee2-bb6a-42cb-9853-3f771516e135

	measure Cosecha =
			
			CALCULATE(
			    [BaseMeasureMani],
			    fact_mani[Attribute] = "superficie_cosechada_ha"
			)
		formatString: 0
		lineageTag: d03f142f-d6a5-4642-957a-eb18b7a33aa4

	measure Siembra =
			
			CALCULATE(
			    [BaseMeasureMani],
			    fact_mani[Attribute] = "superficie_sembrada_ha"
			)
		formatString: 0
		lineageTag: 3841ad00-218e-4a72-9983-071fa3e9c93a

	measure Diferencia = [Siembra] - [Cosecha]
		formatString: 0
		lineageTag: ada7fcb3-2ea3-47bb-bd8e-e5a8294686f2

	column campania
		dataType: string
		lineageTag: 0d67c9b5-d0a5-4f2c-8848-11fe70e675ac
		summarizeBy: none
		sourceColumn: campania

		annotation SummarizationSetBy = Automatic

	column departamento_id
		dataType: int64
		formatString: 0
		lineageTag: 61500e4f-c0cc-492c-812a-5bdeca4a6b9f
		summarizeBy: none
		sourceColumn: departamento_id

		annotation SummarizationSetBy = Automatic

	column date
		dataType: dateTime
		formatString: Long Date
		lineageTag: 0ef826da-d9cf-46c6-874d-ad4c8a6618f4
		summarizeBy: none
		sourceColumn: date

		annotation SummarizationSetBy = Automatic

		annotation UnderlyingDateTimeDataType = Date

	column Value
		dataType: int64
		formatString: 0
		lineageTag: 4027fe71-7862-45d5-8844-dc1f81f6472c
		summarizeBy: sum
		sourceColumn: Value

		annotation SummarizationSetBy = Automatic

	column Attribute
		dataType: string
		lineageTag: b3a09802-2644-490c-a48e-b7461ceee88b
		summarizeBy: none
		sourceColumn: Attribute

		annotation SummarizationSetBy = Automatic

