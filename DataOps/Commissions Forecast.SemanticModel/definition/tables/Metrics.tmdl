	measure 'TAG008 YTD Period' = ```
			
			VAR _startOfYear = FORMAT( DATE(SELECTEDVALUE( 'CALENDAR'[Year] ), 1, 1), "MMM-yy" )
			RETURN
			    _startOfYear & " to " & [TAG005 Current Month] 
			```
		displayFolder: 99.TAGs
		lineageTag: 19de5047-5f89-4ec8-ba5a-78e9a9b3c3dd

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'INV024 PV%' = ```
			
			VAR _grossComAllAgents = 
			    CALCULATE(
			        [INV001 Gross Lease Comm],
			        AGENTS[Agent Type] = "In-House",
			        ALL( AGENTS[Agent Name] )
			    )
			VAR _rate =
			    DIVIDE(
			        [INV003 KWP Gross],
			        _grossComAllAgents
			        )
			VAR _result = 
			    IF( ISINSCOPE( DEALS[Deal ID] ), _rate, BLANK() )
			RETURN
			    _result
			```
		formatString: 0%;-0%;0%
		displayFolder: 01.Invoice
		lineageTag: 7d883fb9-ed72-41d0-a377-24ff2a3b4b99

	measure 'INV025 Net Rate %' = ```
			
			VAR _rate =
			    DIVIDE(
			        [INV004 In-House Agents],
			        [INV003 KWP Gross]
			    )
			VAR _result = 
			    IF( ISINSCOPE( DEALS[Deal ID] ), _rate, BLANK() )
			RETURN
			    _result
			```
		formatString: 0%;-0%;0%
		displayFolder: 01.Invoice
		lineageTag: 83ea9bff-a9a5-4e3e-8f1b-7328f213b07b

