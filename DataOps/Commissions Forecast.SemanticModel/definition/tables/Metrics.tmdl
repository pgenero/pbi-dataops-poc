	measure 'TAG002 Current Period' = ```
			
			VAR _start = MIN('CALENDAR'[Month_Offset])
			VAR _end = MAX('CALENDAR'[Month_Offset])
			VAR _firstMonth = 
			    CALCULATE(
			        SELECTEDVALUE( 'CALENDAR'[Month_Year] ),
			        'CALENDAR'[Month_Offset] = 1
			    )
			VAR __lastMonth = 
			    CALCULATE(
			        SELECTEDVALUE( 'CALENDAR'[Month_Year] ),
			        'CALENDAR'[Month_Offset] = _end
			    )
			RETURN
			_firstMonth & " - " & __lastMonth
			```
		displayFolder: 99.TAGs
		lineageTag: 0c4b09c0-776c-47e4-8ca5-0ad4521c30a4

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'TAG003 Previous Period' = ```
			
			VAR _start = MIN('CALENDAR'[Month_Offset])
			VAR _end = MAX('CALENDAR'[Month_Offset]) - 12
			VAR _firstMonth = 
			    CALCULATE(
			        SELECTEDVALUE( 'CALENDAR'[Month_Year] ),
			        'CALENDAR'[Month_Offset] = ( 1 - 12 )
			    )
			VAR _lastMonth = 
			    CALCULATE(
			        SELECTEDVALUE( 'CALENDAR'[Month_Year] ),
			        'CALENDAR'[Month_Offset] IN {_end}
			    )
			RETURN
			_firstMonth & " - " & _lastMonth
			```
		displayFolder: 99.TAGs
		lineageTag: 47e1c0cc-c3f2-4bb0-9123-c09af677f387

		annotation PBI_FormatHint = {"isGeneralNumber":true}

