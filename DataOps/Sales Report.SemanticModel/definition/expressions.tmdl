expression fxNamesURLReader =
		( _url as text ) =>
		let
		    Source = Csv.Document(Web.Contents(_url),[Delimiter=",", Columns=3, Encoding=65001, QuoteStyle=QuoteStyle.None]),
		    #"Promoted Headers" = Table.PromoteHeaders(Source, [PromoteAllScalars=true]),
		    #"Changed Type" = Table.TransformColumnTypes(#"Promoted Headers",{{"cantidad", Int64.Type}, {"anio", Int64.Type}})
		in
		    #"Changed Type"
	lineageTag: 9a770964-86a7-4488-999f-ad50de9b1863
	queryGroup: Names_Queries

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Function

