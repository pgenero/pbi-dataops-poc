	measure 'INV006 KWP Gross Weight %' =
			
			VAR _baseCommission = [INV000 Base Commission Sum]
			VAR _kwpGrossALL =
			    CALCULATE(
			        [INV003 KWP Gross],
			        ALL( COM_CATEGORY[Commission Category] )
			    )
			VAR _percentage =
			    DIVIDE(
			        _baseCommission,
			        _kwpGrossALL
			    )
			VAR _result =
			    SWITCH(
			        TRUE(),
			        SELECTEDVALUE( COM_CATEGORY[ComCatID] ) IN {1,2}, BLANK(),
			        _percentage
			    )
			RETURN
			    _result
		formatString: #,0.00%;-#,0.00%;#,0.00%
		displayFolder: 01.Invoice
		lineageTag: ebfe9a94-f8db-4815-8443-31e3d57551c1

	measure 'INV011 KWP Gross Agent %' = ```
			
			VAR _allAgentName =
			    CALCULATE(
			        [INV003 KWP Gross],
			        ALL( AGENTS[Agent Name] )
			    )
			VAR _result = 
			    DIVIDE(
			        [INV003 KWP Gross],
			        _allAgentName,
			        0
			    )
			RETURN
			    _result
			```
		formatString: 0.0%;-0.0%;0.0%
		displayFolder: 01.Invoice
		lineageTag: 12e75d66-28c1-46c2-9ea4-da934a6be5db

	measure 'INV008 KWP Gross SPLY Forecast' =
			
			VAR _maxOffset = MAX('CALENDAR'[Month_Offset])
			VAR _result =
			    CALCULATE(
			        [INV007 KWP Gross SPLY],
			        AND( 'CALENDAR'[Month_Offset] >= 0, 'CALENDAR'[Month_Offset] <= _maxOffset)
			    )
			RETURN
			    _result
		formatString: \$#,0.00;(\$#,0.00);\$#,0.00
		displayFolder: 01.Invoice
		lineageTag: 5fce4bea-21d0-4e98-8f79-307a71943e34

