		    #"Remove Current State" = Table.SelectRows(#"Changed Type Name to Date", each [Name] <> Last_History_Update),
		    // Group by Invoice + DueDate + InvoiceDate, adding a column with the latest date from the Name column (date the records were captured). We don't want the entire history; we only want to retain the version prior to the change.
		    #"Grouped History" = Table.Group(#"Remove Current State", {"Invoice Number", "Due Date", "Invoice Date"}, {{"Data", each _, type table [Name=nullable date, Deal ID=nullable number, VendorID=nullable number, Invoice Number=nullable number, Due Date=nullable date, Invoice Date=nullable date, Gross Lease Comm=nullable number, #"KWP Adjusted Gross (House)"=nullable number, #"KWP Net (House)"=nullable number, Broker Share=nullable number, #"Broker Share %"=nullable number, #"KWP Gross (House) %"=nullable number, BrokerRoleID=nullable number]}, {"Snapshot", each List.Max(List.Distinct([Name])), type date}}),
		    #"Keep Data and Snapshot" = Table.SelectColumns(#"Grouped History",{"Data", "Snapshot"}),
		    #"Expanded Data and Snapshot" = Table.ExpandTableColumn(#"Keep Data and Snapshot", "Data", {"Name", "Deal ID", "VendorID", "Invoice Number", "Due Date", "Invoice Date", "Gross Lease Comm", "KWP Adjusted Gross (House)", "KWP Net (House)", "Broker Share", "Broker Share %", "KWP Gross (House) %", "BrokerRoleID"}, {"Name", "Deal ID", "VendorID", "Invoice Number", "Due Date", "Invoice Date", "Gross Lease Comm", "KWP Adjusted Gross (House)", "KWP Net (House)", "Broker Share", "Broker Share %", "KWP Gross (House) %", "BrokerRoleID"}),
