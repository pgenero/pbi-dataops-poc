		    #"Grouped by Invoice" = Table.Group(#"Expanded Data", {"Invoice Number"}, {{"DueDateCheck", each List.Count(List.Distinct([Due Date])), Int64.Type},{"InvoiceDateCheck", each List.Count(List.Distinct([Invoice Date])), Int64.Type}, {"Data", each _, type table [Name=text, Deal ID=text, VendorID=text, Invoice Number=text, Due Date=text, Invoice Date=text, Gross Lease Comm=text, #"KWP Adjusted Gross (House)"=text, #"KWP Net (House)"=text, Broker Share=text, #"Broker Share %"=text, #"KWP Gross (House) %"=text, BrokerRoleID=text]}}),
		    // If the dates columns are greather than 1, it means that the dates were updated. We keep only the rows updated
		    #"Filtered Dates > 1" = Table.SelectRows(#"Grouped by Invoice", each [DueDateCheck] > 1 or [InvoiceDateCheck] > 1),
		    // All the data is stored in the Data column
		    #"Keep Data" = Table.SelectColumns(#"Filtered Dates > 1",{"Data"}),
